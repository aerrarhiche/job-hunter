# DeepSeek V4 Pro
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Apify (for LinkedIn/Indeed scraping)
APIFY_TOKEN=

# Google Custom Search (free: 100/day)
# Setup: https://programmablesearchengine.google.com/
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=jobagent
POSTGRES_USER=jobagent
POSTGRES_PASSWORD=change-me

# Scheduling
DAILY_RUN_HOUR=7
DAILY_RUN_MINUTE=0

# Search criteria
SEARCH_REMOTE_ONLY=true
SEARCH_LOCATIONS=United States,Canada,Remote
SEARCH_EXCLUDE_KEYWORDS=crypto,blockchain,web3,nft,solidity,rust,go,golang,kafka,kubernetes,devops
SEARCH_MUST_HAVE=typescript,next.js,react,python,node.js,aws
SEARCH_ROLE_TITLES=Founding Engineer,Founding Full-Stack,Full-Stack Engineer,Product Engineer,Founding Software Engineer
SEARCH_MIN_SALARY=120000
SEARCH_MIN_SCORE=70
