{
  "name": "job-agent",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f job-agent",
    "db:migrate": "tsx src/db/migrate.ts",
    "scout": "tsx src/index.ts --once",
    "telegram": "tsx src/telegram/bot.ts"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "cron": "^3.1.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "node-telegram-bot-api": "^0.66.0",
    "openai": "^4.73.0",
    "pg": "^8.13.0",
    "puppeteer": "^25.3.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
